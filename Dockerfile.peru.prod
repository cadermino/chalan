FROM node:18-alpine as react-build-stage
WORKDIR /app
COPY /frontend-react/package.json ./
RUN npm install
COPY /frontend-react .
ARG NEXT_PUBLIC_PLACES_API_KEY
ENV NEXT_PUBLIC_PLACES_API_KEY=$NEXT_PUBLIC_PLACES_API_KEY
ENV NODE_OPTIONS=--max-old-space-size=4096
RUN npm run build

FROM node:18-alpine
WORKDIR /chalan/frontend-react-standalone
COPY --from=react-build-stage /app/.next/standalone ./
COPY --from=react-build-stage /app/.next/static ./.next/static
COPY --from=react-build-stage /app/public ./public
